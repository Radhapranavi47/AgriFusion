# Production on Render: use Dashboard Blueprint from repo root `render.yaml`, or set vars manually.
# ML_SERVICE_URL is wired automatically from the `agri-fusion-ml` web service there.

# MongoDB Atlas (recommended): mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/dbname
MONGO_URI=

# Strong secret for JWT signing (generate random string for production)
JWT_SECRET=

# Server port (Render/Fly inject PORT automatically)
PORT=5000

# FastAPI ML service — no trailing slash (local or deployed HTTPS URL)
ML_SERVICE_URL=http://localhost:8000

# Optional APIs used by backend services
DATA_GOV_API_KEY=
VISUAL_CROSSING_API_KEY=

NODE_ENV=production
